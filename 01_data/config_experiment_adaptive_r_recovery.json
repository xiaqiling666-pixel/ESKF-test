{
  "config_metadata": {
    "profile": "experiment",
    "name": "eskf_adaptive_r_recovery",
    "purpose": "实验模板：开启 NIS reject、adaptive R 和 recovery scale，作为完整 measurement manager 策略。"
  },
  "dataset_path": "01_data/generated/demo_sensor_log.csv",
  "dataset_adapter": {
    "kind": "standard_csv"
  },
  "results_dir": "03_results_experiment_adaptive_r_recovery",
  "gravity": [0.0, 0.0, -9.81],
  "process_noise": {
    "accel_std": 0.08,
    "gyro_std": 0.01,
    "gyro_bias_std": 0.0005,
    "accel_bias_std": 0.005
  },
  "measurement_noise": {
    "gnss_pos_std": 0.8,
    "gnss_vel_std": 0.2,
    "baro_std": 0.35,
    "yaw_std_deg": 3.0
  },
  "initial_covariance": {
    "pos_std": 1.5,
    "vel_std": 0.8,
    "att_std_deg": 12.0,
    "gyro_bias_std": 0.01,
    "accel_bias_std": 0.2
  },
  "initialization": {
    "static_coarse_alignment_enabled": true,
    "static_window_duration_s": 2.0,
    "static_window_min_samples": 50,
    "static_max_accel_std_mps2": 0.25,
    "static_max_gyro_std_radps": 0.03,
    "static_gravity_norm_tolerance_mps2": 1.5,
    "bootstrap_min_dt_s": 0.15,
    "bootstrap_min_horizontal_displacement_m": 0.5,
    "heading_wait_timeout_s": 2.0,
    "zero_yaw_fallback_enabled": false
  },
  "time_step_management": {
    "min_positive_dt_s": 0.0001,
    "max_dt_s": 0.2,
    "skip_large_dt": true
  },
  "innovation_management": {
    "gnss_pos_nis_adapt_threshold": 7.815,
    "gnss_pos_nis_reject_threshold": 16.266,
    "gnss_vel_nis_adapt_threshold": 7.815,
    "gnss_vel_nis_reject_threshold": 16.266,
    "baro_nis_adapt_threshold": 3.841,
    "baro_nis_reject_threshold": 10.828,
    "mag_yaw_nis_adapt_threshold": 3.841,
    "mag_yaw_nis_reject_threshold": 10.828
  },
  "fusion_policy": {
    "use_nis_rejection": true,
    "use_adaptive_r": true,
    "use_recovery_scale": true
  },
  "navigation_environment": {
    "frame": "ENU",
    "reference_lat_deg": 22.3027,
    "reference_lon_deg": 114.1772,
    "reference_height_m": 0.0,
    "use_wgs84_gravity": true,
    "use_earth_rotation": true
  },
  "use_baro": true,
  "use_mag": true
